# ============================================================
# Fazle Personal AI System — Environment Variables
# Add these to your existing .env file
# ============================================================

# ── LLM Configuration ──────────────────────────────────────
# OpenAI API key (required for OpenAI provider)
OPENAI_API_KEY=sk-your-openai-api-key

# LLM provider: "openai" or "ollama"
FAZLE_LLM_PROVIDER=openai

# Model for OpenAI
FAZLE_LLM_MODEL=gpt-4o

# Model for Ollama (used when FAZLE_LLM_PROVIDER=ollama)
FAZLE_OLLAMA_MODEL=llama3.1

# ── Search API ──────────────────────────────────────────────
# Serper API key for Google search
SERPER_API_KEY=your-serper-api-key

# Tavily API key (alternative to Serper)
TAVILY_API_KEY=

# Search provider: "serper" or "tavily"
FAZLE_SEARCH_PROVIDER=serper

# ── Security ───────────────────────────────────────────────
# API key for Fazle endpoints (optional, leave empty to disable)
FAZLE_API_KEY=

# ── Vector DB ──────────────────────────────────────────────
# Qdrant URL (internal Docker network)
VECTOR_DB_URL=http://qdrant:6333

# ── Ollama ─────────────────────────────────────────────────
# Ollama URL (internal Docker network)
OLLAMA_URL=http://ollama:11434
