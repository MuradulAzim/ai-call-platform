# ============================================================
# WBOM — Environment Variables Example  (Sprint-6 S6-12)
# Copy to .env and fill in real values before starting.
# NEVER commit real secrets to version control.
# ============================================================

# ── Database ──────────────────────────────────────────────────
# Full PostgreSQL DSN. Overrides all DB_* vars below.
WBOM_DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/postgres

# ── Internal Auth ─────────────────────────────────────────────
# Shared secret between fazle-api / social-engine → wbom.
# Generate with: openssl rand -hex 32
WBOM_INTERNAL_KEY=

# ── WhatsApp API ──────────────────────────────────────────────
WBOM_WHATSAPP_API_URL=https://graph.facebook.com/v18.0
WBOM_WHATSAPP_PHONE_NUMBER_ID=
WBOM_WHATSAPP_ACCESS_TOKEN=
WBOM_WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# ── Core AI / Brain Integration ───────────────────────────────
WBOM_CORE_API_URL=http://fazle-brain:8200/api
WBOM_CORE_API_KEY=

# ── AI Processing Thresholds ──────────────────────────────────
WBOM_CONFIDENCE_THRESHOLD=0.7
WBOM_AUTO_PROCESS_THRESHOLD=0.9
WBOM_MAX_EXTRACTION_ATTEMPTS=3

# ── Business Rules ────────────────────────────────────────────
WBOM_DEFAULT_SERVICE_CHARGE=2000
WBOM_PER_PROGRAM_ALLOWANCE=500
WBOM_MAX_ADVANCE_PERCENTAGE=0.5
# Shift hours (24h): 6 = 6 AM day start, 18 = 6 PM night start
WBOM_SHIFT_DAY_START=6
WBOM_SHIFT_NIGHT_START=18

# ── Validation ────────────────────────────────────────────────
WBOM_MOBILE_FORMAT=BD
WBOM_DATE_FORMAT=%d.%m.%Y
WBOM_REQUIRE_ADMIN_APPROVAL=true
WBOM_ALLOW_VALIDATION_OVERRIDE=true

# ── Server ────────────────────────────────────────────────────
WBOM_PORT=9900

# ── Log level (DEBUG | INFO | WARNING | ERROR) ────────────────
WBOM_LOG_LEVEL=INFO
